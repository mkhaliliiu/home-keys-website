---
layout: base.njk
pagination:
  data: properties
  size: 1
  alias: prop
permalink: "properties/{{ prop.slug }}/index.html"
---

{% block extraCss %}
<link rel="stylesheet" href="/secondary-properties.css" />
<link rel="stylesheet" href="/property-detail.css" />
{% endblock %}

{% block content %}

<!-- HERO -->
<section class="pd-hero">
  <div class="pd-hero-bg" style="background-image:url('{{ prop.mainImage }}')"></div>
  <div class="pd-hero-overlay"></div>
  <div class="pd-hero-content">

    <div class="pd-hero-breadcrumb">
      <a href="/"><i class="fa fa-home mr-1"></i>Home</a>
      <i class="fa fa-chevron-right"></i>
      <a href="/sproperties.html">Properties</a>
      <i class="fa fa-chevron-right"></i>
      <span>{{ prop.title }}</span>
    </div>

    <div class="pd-hero-badges">
      <span class="sp-badge {% if prop.status == 'sale' %}sp-badge-sale{% else %}sp-badge-rent{% endif %}">
        For {{ prop.status | capitalize }}
      </span>
      {% if prop.goldenVisa %}
      <span class="sp-badge sp-badge-featured">Golden Visa Eligible</span>
      {% endif %}
      <span class="pd-hero-devbadge">{{ prop.developer | upper }}</span>
    </div>

    <h1 class="pd-hero-title">{{ prop.title }}</h1>
    <p class="pd-hero-location">
      <i class="fa fa-map-marker-alt mr-2 text-primary"></i>
      {{ prop.fullAddress if prop.fullAddress else prop.area + ', ' + prop.city | capitalize + ', UAE' }}
    </p>

    <div class="pd-hero-stats">
      <div class="pd-hstat"><strong>{{ prop.priceLabel }}</strong><span>Price</span></div>
      <div class="pd-hstat-div"></div>
      <div class="pd-hstat"><strong>{{ prop.beds }}</strong><span>Bedrooms</span></div>
      <div class="pd-hstat-div"></div>
      <div class="pd-hstat"><strong>{{ prop.sqft }}</strong><span>Sq Ft</span></div>
      <div class="pd-hstat-div"></div>
      <div class="pd-hstat"><strong>{{ prop.completion if prop.completion else 'Ready' }}</strong><span>Status</span></div>
      <div class="pd-hstat-div"></div>
      <div class="pd-hstat"><strong>{{ prop.reference if prop.reference else 'HK-001' }}</strong><span>Ref No.</span></div>
    </div>

    <div class="pd-hero-actions">
      <button class="pd-hero-action-btn" id="wishlistTopBtn" onclick="toggleWishlist()">
        <i class="fa fa-heart mr-2"></i>Save
      </button>
      <button class="pd-hero-action-btn" onclick="shareProperty()">
        <i class="fa fa-share-alt mr-2"></i>Share
      </button>
      <a href="/sproperties.html" class="pd-hero-action-btn">
        <i class="fa fa-arrow-left mr-2"></i>Back
      </a>
      <a href="#gallery" class="pd-hero-action-btn pd-hero-photos-btn">
        <i class="fa fa-images mr-2"></i>View Photos
      </a>
    </div>

  </div>
</section>

<!-- GALLERY -->
<section class="pd-gallery-section" id="gallery">
  <div class="pd-gallery-header">
    <h2 class="pd-gallery-title">
      <i class="fa fa-images text-primary mr-2"></i>Property Gallery
      <span class="pd-gallery-count">{{ prop.gallery | length }} Photos</span>
    </h2>
  </div>

  <div class="pd-slider-wrap">
    <div class="pd-slider-track" id="sliderTrack">
      {% for img in prop.gallery %}
      <div class="pd-slide">
        <img src="{{ img }}" alt="{{ prop.title }}" loading="lazy" />
      </div>
      {% endfor %}
    </div>
    <button class="pd-slider-arrow pd-slider-prev" id="sliderPrev"><i class="fa fa-chevron-left"></i></button>
    <button class="pd-slider-arrow pd-slider-next" id="sliderNext"><i class="fa fa-chevron-right"></i></button>
    <div class="pd-slider-counter" id="sliderCounter">1 / {{ prop.gallery | length }}</div>
    <button class="pd-slider-expand" onclick="openLightbox(currentSlide)"><i class="fa fa-expand-alt"></i></button>
  </div>
  <div class="pd-slider-dots" id="sliderDots"></div>
  <div class="pd-thumb-strip" id="thumbStrip"></div>
</section>

<!-- LIGHTBOX -->
<div class="pd-lightbox" id="lightbox">
  <button class="pd-lb-close" onclick="closeLightbox()"><i class="fa fa-times"></i></button>
  <button class="pd-lb-prev" onclick="lbNav(-1)"><i class="fa fa-chevron-left"></i></button>
  <button class="pd-lb-next" onclick="lbNav(1)"><i class="fa fa-chevron-right"></i></button>
  <div class="pd-lb-content">
    <img id="lbImg" src="" alt="Gallery" />
    <div class="pd-lb-counter" id="lbCounter"></div>
  </div>
</div>

<!-- MAIN CONTENT -->
<main class="pd-main">
  <div class="pd-container">
    <div class="pd-layout">

      <!-- LEFT COLUMN -->
      <div class="pd-info-col">

        <!-- Title Block -->
        <div class="pd-title-block">
          <div class="pd-title-top">
            <div class="pd-prop-type">
              <i class="fa fa-home mr-1"></i>{{ prop.type | capitalize }} · {{ prop.area }}
            </div>
            <div class="pd-ref">Ref: {{ prop.reference if prop.reference else 'HK-001' }}</div>
          </div>
          <h1 class="pd-title">{{ prop.title }}</h1>
          <div class="pd-location">
            <i class="fa fa-map-marker-alt text-primary mr-2"></i>
            {{ prop.fullAddress if prop.fullAddress else prop.area + ', UAE' }}
          </div>
          <div class="pd-price-row">
            <div class="pd-price">{{ prop.priceLabel }}</div>
            <div class="pd-price-sub">{{ prop.sqft }} sqft · AED {{ (prop.price / prop.sqft) | round }} / sqft</div>
          </div>
        </div>

        <!-- Quick Stats -->
        <div class="pd-quick-stats">
          <div class="pd-qs-item"><i class="fa fa-bed pd-qs-icon"></i><strong>{{ prop.beds }}</strong><span>Bedrooms</span></div>
          <div class="pd-qs-div"></div>
          <div class="pd-qs-item"><i class="fa fa-bath pd-qs-icon"></i><strong>{{ prop.baths }}</strong><span>Bathrooms</span></div>
          <div class="pd-qs-div"></div>
          <div class="pd-qs-item"><i class="fa fa-vector-square pd-qs-icon"></i><strong>{{ prop.sqft }}</strong><span>sqft</span></div>
          <div class="pd-qs-div"></div>
          <div class="pd-qs-item"><i class="fa fa-car pd-qs-icon"></i><strong>{{ prop.parking if prop.parking else '1' }}</strong><span>Parking</span></div>
          <div class="pd-qs-div"></div>
          <div class="pd-qs-item"><i class="fa fa-layer-group pd-qs-icon"></i><strong>{{ prop.floors if prop.floors else 'G+1' }}</strong><span>Floors</span></div>
        </div>

        <!-- Tabs -->
        <div class="pd-tabs-nav">
          <button class="pd-tab-btn active" data-tab="overview">Overview</button>
          <button class="pd-tab-btn" data-tab="features">Features</button>
          <button class="pd-tab-btn" data-tab="location">Location</button>
        </div>

        <!-- TAB: OVERVIEW -->
        <div class="pd-tab-content active" id="tab-overview">

          <div class="pd-section">
            <h2 class="pd-section-title"><span class="pd-section-dot"></span>About This Property</h2>
            <div class="pd-description">
              <p>{{ prop.description }}</p>
            </div>
          </div>

          <div class="pd-section">
            <h2 class="pd-section-title"><span class="pd-section-dot"></span>Property Details</h2>
            <div class="pd-details-grid">
              <div class="pd-detail-row"><span>Property Type</span><strong>{{ prop.type | capitalize }}</strong></div>
              <div class="pd-detail-row"><span>Status</span><strong class="text-primary">For {{ prop.status | capitalize }}</strong></div>
              <div class="pd-detail-row"><span>Developer</span><strong>{{ prop.developer | upper }}</strong></div>
              <div class="pd-detail-row"><span>Community</span><strong>{{ prop.area }}</strong></div>
              <div class="pd-detail-row"><span>Bedrooms</span><strong>{{ prop.beds }}</strong></div>
              <div class="pd-detail-row"><span>Bathrooms</span><strong>{{ prop.baths }}</strong></div>
              <div class="pd-detail-row"><span>Total Area</span><strong>{{ prop.sqft }} sqft</strong></div>
              <div class="pd-detail-row"><span>Parking</span><strong>{{ prop.parking if prop.parking else '1' }}</strong></div>
              <div class="pd-detail-row"><span>Furnishing</span><strong>{{ prop.furnishing if prop.furnishing else 'N/A' }}</strong></div>
              <div class="pd-detail-row"><span>Completion</span><strong>{{ prop.completion if prop.completion else 'Ready' }}</strong></div>
              <div class="pd-detail-row"><span>View</span><strong>{{ prop.view if prop.view else 'N/A' }}</strong></div>
              <div class="pd-detail-row"><span>Ownership</span><strong>{{ prop.ownership if prop.ownership else 'Freehold' }}</strong></div>
              <div class="pd-detail-row"><span>Service Charges</span><strong>{{ prop.serviceCharges if prop.serviceCharges else 'N/A' }}</strong></div>
              <div class="pd-detail-row"><span>Reference</span><strong>{{ prop.reference if prop.reference else 'HK-001' }}</strong></div>
              {% if prop.goldenVisa %}
              <div class="pd-detail-row"><span>Golden Visa</span><strong class="text-primary">Eligible</strong></div>
              {% endif %}
            </div>
          </div>

          {% if prop.tags %}
          <div class="pd-section">
            <h2 class="pd-section-title"><span class="pd-section-dot"></span>Highlights</h2>
            <div class="pd-highlight-tags">
              {% for tag in prop.tags %}
              <span><i class="fa fa-check-circle mr-1 text-primary"></i>{{ tag }}</span>
              {% endfor %}
            </div>
          </div>
          {% endif %}

          <!-- Investment Snapshot -->
          {% if prop.rentalYield %}
          <div class="pd-section">
            <h2 class="pd-section-title"><span class="pd-section-dot"></span>Investment Snapshot</h2>
            <div class="pd-roi-grid">
              <div class="pd-roi-card pd-roi-primary">
                <i class="fa fa-chart-line"></i>
                <strong>{{ prop.rentalYield }}</strong>
                <span>Est. Gross Yield</span>
              </div>
              {% if prop.annualRent %}
              <div class="pd-roi-card">
                <i class="fa fa-money-bill-wave"></i>
                <strong>{{ prop.annualRent }}</strong>
                <span>Est. Annual Rent</span>
              </div>
              {% endif %}
              {% if prop.capitalGrowth %}
              <div class="pd-roi-card">
                <i class="fa fa-arrow-trend-up"></i>
                <strong>{{ prop.capitalGrowth }}</strong>
                <span>Capital Growth</span>
              </div>
              {% endif %}
              {% if prop.goldenVisa %}
              <div class="pd-roi-card">
                <i class="fa fa-medal"></i>
                <strong>Golden Visa</strong>
                <span>Eligible</span>
              </div>
              {% endif %}
            </div>
          </div>
          {% endif %}

        </div>

        <!-- TAB: FEATURES -->
        <div class="pd-tab-content" id="tab-features">
          {% if prop.amenities %}
          <div class="pd-section">
            <h2 class="pd-section-title"><span class="pd-section-dot"></span>Amenities & Features</h2>
            <div class="pd-amenity-list">
              {% for item in prop.amenities %}
              <div class="pd-amenity"><i class="fa fa-check"></i>{{ item }}</div>
              {% endfor %}
            </div>
          </div>
          {% endif %}
        </div>

        <!-- TAB: LOCATION -->
        <div class="pd-tab-content" id="tab-location">
          <div class="pd-section">
            <h2 class="pd-section-title"><span class="pd-section-dot"></span>Location</h2>
            <div class="pd-map-wrap">
              <iframe
  src="https://maps.google.com/maps?q={{ prop.fullAddress | urlencode if prop.fullAddress else prop.area | urlencode }},UAE&output=embed&z=15"
  width="100%" height="320"
  style="border:0;border-radius:12px;"
  allowfullscreen="" loading="lazy">
</iframe>
            </div>
            <p style="font-size:0.8rem;color:var(--gray-400);margin-top:8px;">
              <i class="fa fa-map-marker-alt text-primary mr-1"></i>
              {{ prop.fullAddress if prop.fullAddress else prop.area + ', ' + prop.city | capitalize + ', UAE' }}
            </p>
          </div>
        </div>

      </div>

      <!-- RIGHT SIDEBAR -->
      <aside class="pd-sidebar">

        <!-- Price & Contact Card -->
        <div class="pd-price-card">
          <div class="pd-pc-price">{{ prop.priceLabel }}</div>
          <div class="pd-pc-sub">
            {% if prop.completion %}{{ prop.completion }}{% else %}Ready to Move{% endif %}
          </div>
          <div class="pd-pc-divider"></div>

          <div class="pd-company-row">
            <div class="pd-company-logo-wrap">
              <img src="/assets/HomeKeys logo-1 PNG.png" alt="HomeKeys" class="pd-company-logo" />
            </div>
            <div class="pd-company-info">
              <strong>HomeKeys Real Estate</strong>
              <span>RERA Registered · Reg. No: 12345-UAE</span>
              <div class="pd-company-location">
                <i class="fa fa-map-marker-alt mr-1 text-primary"></i>Dubai, UAE
              </div>
            </div>
          </div>

          <div class="pd-cta-btns">
            <a href="tel:+97145693313" class="pd-cta-primary">
              <i class="fa fa-phone mr-2"></i>+971 4 569 3313
            </a>
            <a href="https://wa.me/97145693313?text=Hi, I'm interested in {{ prop.title | urlencode }} (Ref: {{ prop.reference }})" target="_blank" class="pd-cta-wa">
              <i class="fab fa-whatsapp mr-2"></i>WhatsApp Us
            </a>
            <a href="mailto:info@homekeys.ae?subject=Enquiry: {{ prop.title }}" class="pd-cta-email">
              <i class="fa fa-envelope mr-2"></i>info@homekeys.ae
            </a>
          </div>

          <div class="pd-office-hours">
            <i class="fa fa-clock text-primary mr-2"></i>
            <span>Mon–Sat: 9:00 AM – 9:00 PM</span>
          </div>
        </div>

        <!-- Enquiry Form -->
        <div class="pd-enquiry-card">
          <h4 class="pd-enquiry-title">
            <i class="fa fa-comment-dots text-primary mr-2"></i>Send Enquiry
          </h4>
          <form id="enquiryForm" class="pd-enquiry-form">
            <input type="hidden" name="property" value="{{ prop.title }}" />
            <input type="hidden" name="ref" value="{{ prop.reference }}" />
            <div class="pd-form-group">
              <input type="text" placeholder="Your Full Name *" required />
            </div>
            <div class="pd-form-group">
              <input type="email" placeholder="Email Address *" required />
            </div>
            <div class="pd-form-group">
              <input type="tel" placeholder="Phone Number *" required />
            </div>
            <div class="pd-form-group">
              <select>
                <option value="">I'm interested in...</option>
                <option>Buying this property</option>
                <option>Getting more info</option>
                <option>Arranging a viewing</option>
                <option>Making an offer</option>
              </select>
            </div>
            <div class="pd-form-group">
              <textarea placeholder="Your message (optional)" rows="3"></textarea>
            </div>
            <button type="submit" class="pd-enquiry-submit">
              <i class="fa fa-paper-plane mr-2"></i>Send Message
            </button>
            <p class="pd-form-note">
              <i class="fa fa-lock mr-1"></i>Your info is secure.
            </p>
          </form>
        </div>

        <!-- Quick Actions -->
        <div class="pd-quick-actions">
          <button class="pd-qa-btn" id="wishlistSideBtn" onclick="toggleWishlist()">
            <i class="fa fa-heart mr-2"></i>Save to Wishlist
          </button>
          <button class="pd-qa-btn" onclick="shareProperty()">
            <i class="fa fa-share-alt mr-2"></i>Share Property
          </button>
          <a href="/sproperties.html" class="pd-qa-btn">
            <i class="fa fa-th-large mr-2"></i>All Properties
          </a>
        </div>

        <!-- Mortgage Calculator -->
        <div class="pd-mortgage-card">
          <h4><i class="fa fa-calculator text-primary mr-2"></i>Mortgage Estimator</h4>
          <div class="pd-mort-inputs">
            <div class="pd-mort-row">
              <label>Price (AED)</label>
              <input type="number" id="mortPrice" value="{{ prop.price }}" onchange="calcMortgage()" />
            </div>
            <div class="pd-mort-row">
              <label>Down Payment (%)</label>
              <input type="number" id="mortDown" value="20" min="5" max="90" onchange="calcMortgage()" />
            </div>
            <div class="pd-mort-row">
              <label>Interest Rate (%)</label>
              <input type="number" id="mortRate" value="4.5" step="0.1" onchange="calcMortgage()" />
            </div>
            <div class="pd-mort-row">
              <label>Term (Years)</label>
              <input type="number" id="mortTerm" value="25" min="5" max="30" onchange="calcMortgage()" />
            </div>
          </div>
          <div class="pd-mort-result">
            <div class="pd-mort-result-row">
              <span>Loan Amount</span>
              <strong id="mortLoan">Calculating...</strong>
            </div>
            <div class="pd-mort-result-row">
              <span>Monthly Payment</span>
              <strong id="mortMonthly" class="text-primary">Calculating...</strong>
            </div>
            <div class="pd-mort-result-row">
              <span>Down Payment</span>
              <strong id="mortDownAmt">Calculating...</strong>
            </div>
          </div>
          <p class="pd-mort-note">* Indicative estimate only.</p>
        </div>

      </aside>
    </div>
  </div>
</main>

{% endblock %}

{% block extraJs %}
<script src="/property-detail.js"></script>
{% endblock %}